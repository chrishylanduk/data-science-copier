# Environment Variables Template
# Copy this file to .env and fill in your actual values
#
# Environment variables can be read in Python using the `python-dotenv` package:
#
#   ------------------------------------------------------------------------------------
#   from dotenv import load_dotenv
#   import os
#
#   # Load the environment variables from the `.env` file
#   load_dotenv(override=True)
#
#   # Example variable
#   API_KEY = os.getenv("API_KEY")
#   ------------------------------------------------------------------------------------
#
# For folder/file path environment variables, use relative paths.
# The .env file is ignored by git - you can store secrets there safely.

API_KEY=your-api-key
